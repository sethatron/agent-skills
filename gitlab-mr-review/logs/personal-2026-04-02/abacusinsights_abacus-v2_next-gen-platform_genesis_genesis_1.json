    {
      "diff": "@@ -0,0 +1,11 @@\n+variables:\n+  SOUSCHEF_VERSION: &_SOUSCHEF_VERSION \"master\"\n+  SOUSCHEF_VARIANT: \"terraform1.1.7-py3.10\"\n+\n+include:\n+  - project: \"abacusinsights/lunatic-dove/kitchen-souschef\"\n+    file: \"/gitlab_templates/base/all.yml\"\n+    ref: *_SOUSCHEF_VERSION\n+  - project: 'abacusinsights/lunatic-dove/kitchen-souschef'\n+    file: '/gitlab_templates/kaniko/all.yml'\n+    ref: *_SOUSCHEF_VERSION\n",
      "collapsed": false,
      "too_large": false,
      "new_path": ".gitlab-ci.yml",
      "old_path": ".gitlab-ci.yml",
      "a_mode": "0",
      "b_mode": "100644",
