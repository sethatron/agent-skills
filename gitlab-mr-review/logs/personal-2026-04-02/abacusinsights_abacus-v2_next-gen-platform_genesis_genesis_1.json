      "renamed_file": false,
      "deleted_file": false,
      "generated_file": false
    },
    {
      "diff": "@@ -0,0 +1,30 @@\n+FROM ghcr.io/genesis-computing-ai/genesis:v1.12.0-rc.1\n+\n+# Strip setuid/setgid bits to prevent privilege-escalation via suid binaries\n+RUN find / -xdev -perm /6000 -type f -exec chmod a-s {} + 2>/dev/null || true \\\n+# Remove package managers to block runtime software installation\n+    && rm -f /usr/bin/apt* /usr/bin/dpkg* /usr/sbin/dpkg* \\\n+    && rm -rf /var/lib/apt /var/lib/dpkg /var/cache/apt /etc/apt \\\n+    && rm -f /usr/local/bin/pip /usr/local/bin/pip3 \\\n+             /usr/bin/pip /usr/bin/pip3 \\\n+    && rm -f /usr/local/bin/npm /usr/local/bin/yarn \\\n+             /usr/bin/npm /usr/bin/yarn \\\n+    && rm -rf /usr/local/lib/node_modules/npm \\\n+              /usr/local/share/.config/yarn \\\n+    && ln -sf /bin/bash /bin/sh \\\n+# Create non-root user (UID 10001) to run the app\n+    && groupadd -g 10001 genesis \\\n+    && useradd -u 10001 -g 10001 -s /bin/bash -d /app genesis \\\n+    && chown -R genesis:genesis /app /opt/genesis \\\n+    && mkdir -p /tmp && chmod 1777 /tmp \\\n+# Purge caches and docs to reduce attack surface\n+    && rm -rf /var/cache/* /var/log/* /var/lib/apt/lists/* \\\n+              /root/.cache /root/.npm /root/.config /root/.local \\\n+              /usr/share/doc /usr/share/man /usr/share/info \\\n+              /usr/share/lintian 2>/dev/null || true\n+\n+ENV HOME=/app\n+\n+USER 10001\n+\n+EXPOSE 8080 8082 8501\n",
      "collapsed": false,
      "too_large": false,
      "new_path": "Dockerfile",
      "old_path": "Dockerfile",
