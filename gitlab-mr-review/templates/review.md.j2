---
mr_id: {{ frontmatter.mr_id }}
mr_iid: {{ frontmatter.mr_iid }}
mr_url: "{{ frontmatter.mr_url }}"
project: "{{ frontmatter.project }}"
title: "{{ frontmatter.title }}"
author: "{{ frontmatter.author }}"
source_branch: "{{ frontmatter.source_branch }}"
target_branch: "{{ frontmatter.target_branch }}"
state: {{ frontmatter.state }}
pipeline_status: {{ frontmatter.pipeline_status }}
pipeline_url: {{ frontmatter.pipeline_url | default("null", true) }}
has_conflicts: {{ frontmatter.has_conflicts | lower }}
approvals_required: {{ frontmatter.approvals_required }}
approvals_given: {{ frontmatter.approvals_given }}
approved_by: {{ frontmatter.approved_by | tojson }}
verdict_critical: {{ frontmatter.verdict_critical }}
verdict_major: {{ frontmatter.verdict_major }}
verdict_minor: {{ frontmatter.verdict_minor }}
verdict_suggestion: {{ frontmatter.verdict_suggestion }}
linked_issues: {{ frontmatter.linked_issues | tojson }}
review_timestamp: "{{ frontmatter.review_timestamp }}"
review_path: "{{ frontmatter.review_path }}"
previous_review_path: {{ frontmatter.previous_review_path | default("null", true) }}
skill_version: "{{ frontmatter.skill_version }}"
jira_key: {{ frontmatter.jira_key | default("null", true) }}
jira_url: {{ frontmatter.jira_url | default("null", true) }}
